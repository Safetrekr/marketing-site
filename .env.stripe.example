# Stripe Configuration - Marketing Site
# Copy this file to .env and fill in your Stripe keys

# Stripe Publishable Key (client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Secret Key (server-side only - for Edge Functions)
# Add this to Supabase Edge Functions secrets
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Webhook Secret
# Get this from Stripe Dashboard > Developers > Webhooks
# Add webhook endpoint: https://your-project.supabase.co/functions/v1/marketing-stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (from products created in Stripe Dashboard)
STRIPE_PRICE_T1=price_1SNaTMPih7iRZkzn6O2fIyak
STRIPE_PRICE_T2=price_1SNaTMPih7iRZkznG5h21SKV
STRIPE_PRICE_T3=price_1SNaTMPih7iRZkzn7AqXz0Yq

# Background Check Price IDs
STRIPE_PRICE_BG_DOMESTIC=price_1SNaTMPih7iRZkzn1zkBXChh
STRIPE_PRICE_BG_INTERNATIONAL=price_1SNaTNPih7iRZkznRfXqX0vy

# Supabase Configuration (if not already set)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
